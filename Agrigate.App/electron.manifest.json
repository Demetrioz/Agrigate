{
  "executable": "Agrigate.App",
  "splashscreen": {
    "imageFile": "/wwwroot/assets/img/splash.png"
  },
  "name": "Agrigate",
  "author": "",
  "singleInstance": false,
  "environment": "Production",
  "build": {
    "appId": "com.Agrigate.App.app",
    "productName": "Agrigate",
    "copyright": "Copyright © 2025",
    "buildVersion": "0.1.0",
    "compression": "maximum",
    "win": {
      "icon": "Assets/logo.ico",
      "publish": [
        {
          "provider": "github",
          "owner": "Kevin Williams",
          "repo": "Agrigate",
          "token": ""
        }
      ]
    },
    "directories": {
      "output": "../../../bin/Desktop"
    },
    "extraResources": [
      {
        "from": "./bin",
        "to": "bin",
        "filter": [ "**/*" ]
      }
    ],
    "files": [
      {
        "from": "./ElectronHostHook/node_modules",
        "to": "ElectronHostHook/node_modules",
        "filter": [ "**/*" ]
      },
      "**/*"
    ]
  }
}