{
  "SeriLog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff}] :: [{Level:u3}] :: {Message:lj}{NewLine}"
        }
      },
      { 
        "Name": "File", 
        "Args": { 
          "path": "log.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 5,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff}] :: [{Level:u3}] :: {Message:lj}{NewLine}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
