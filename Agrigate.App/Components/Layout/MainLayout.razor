@inherits MainLayoutBase

<MudThemeProvider Theme="AgrigateTheme"/>
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Dense="true">
        <MudText Typo="Typo.h6">Agrigate</MudText>
    </MudAppBar>
    <MudDrawer
        @bind-Open="@DrawerOpen"
        ClipMode="DrawerClipMode.Always"
        Variant="DrawerVariant.Mini"
        Breakpoint="Breakpoint.None"
        OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <div class="wrapper">
            @Body
        </div>
    </MudMainContent>
</MudLayout>