@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar>
        <MudIconButton
            Icon="@Icons.Material.Filled.Menu"
            Color="Color.Inherit"
            Edge="Edge.Start" />
        Agrigate
    </MudAppBar>
    <MudDrawer
        @bind-Open="@_drawerOpen"
        ClipMode="DrawerClipMode.Always"
        Variant="DrawerVariant.Mini"
        Breakpoint="Breakpoint.None"
        OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="m-4">
        @Body
    </MudMainContent>
</MudLayout>

@code
{
    private bool _drawerOpen = false;
}