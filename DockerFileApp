FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base
WORKDIR /app
EXPOSE 5000

ENV Authentication__DefaultUser=admin
ENV Authentication__DefaultPassword=Ag@dm1n!

ENV ASPNETCORE_URLS=http://+:5000

FROM mcr.microsoft.com/dotnet/sdk:8.0 as build
WORKDIR /src

COPY ["Agrigate.Domain.Auth/Agrigate.Domain.Auth.csproj", "Agrigate.Domain.Auth/"]
COPY ["Agrigate.App/Agrigate.App.csproj", "Agrigate.App/"]

RUN dotnet restore "Agrigate.Domain.Auth/Agrigate.Domain.Auth.csproj"
RUN dotnet restore "Agrigate.App/Agrigate.App.csproj"

COPY . .

WORKDIR "/src/Agrigate.App"

RUN dotnet build "Agrigate.App.csproj" -c Release -o /app/build

FROM build as publish
RUN dotnet publish "Agrigate.App.csproj" -c Release -o /app/publish

FROM base as final
WORKDIR /app

COPY --from=publish /app/publish .

ENTRYPOINT ["dotnet", "Agrigate.App.dll"]
    